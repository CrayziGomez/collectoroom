# ==============================================
# Collectoroom Environment Configuration
# ==============================================
# Copy this file to .env.local and fill in your values

# ---------------------------------------------
# Clerk Authentication (keep existing)
# ---------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Optional Clerk URLs (defaults work for most cases)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# ---------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------
DATABASE_URL=postgresql://collectoroom:dev_password_change_me@localhost:5432/collectoroom

# ---------------------------------------------
# Storage (S3-compatible - MinIO for local dev)
# ---------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=collectoroom
S3_REGION=us-east-1

# For production, use your S3-compatible provider:
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1

# Public URL for serving images (MinIO local)
S3_PUBLIC_URL=http://localhost:9000/collectoroom

# ---------------------------------------------
# Legacy Firebase (TO BE REMOVED after migration)
# ---------------------------------------------
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

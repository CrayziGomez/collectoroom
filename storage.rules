
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Public Read Access ---
    // Anyone can read any file. This is simple and effective for public content like
    // avatars, collection covers, and card images. Write access is still protected.
    match /{allPaths=**} {
      allow read;
    }

    // --- WRITE RULES START HERE ---

    // Helper function to check if the user is the owner of the resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- Admin SDK Rule ---
    // This allows server-side actions (like our createCollection and updateAvatar functions)
    // to write files. The `request.auth == null` condition is true for the Admin SDK.
    // It is placed after the public read so it doesn't get overridden.
    match /{allPaths=**} {
        allow write: if request.auth == null;
    }

    // USER PROFILE IMAGES
    // A user can only write to their own profile folder.
    // The uploaded file must be an image and under 2MB.
    match /users/{userId}/profile/{fileName} {
      allow write: if isOwner(userId) 
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
    
    // COLLECTION COVER IMAGES
    // A user can only write to a collection folder under their own user ID.
    // The file must be an image and under 5MB.
    match /users/{userId}/collections/{collectionId}/{fileName} {
       allow write: if isOwner(userId)
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }
    
    // CARD IMAGES
    // A user can only write to a card folder under their own user ID.
    // The file must be an image and under 5MB.
     match /users/{userId}/cards/{cardId}/{fileName} {
       allow write: if isOwner(userId)
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }

    // SITE CONTENT IMAGES
    // Allow admins to upload images for site content (like the homepage hero).
    match /site-content/{allPaths=**} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}

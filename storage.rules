rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to read and write to their own folder
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow any authenticated user to write to the site-content folder
    // This is used for general site assets like the homepage hero image.
    match /site-content/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

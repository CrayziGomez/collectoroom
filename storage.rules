rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is the owner of the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Admin SDK Bypass ---
    // Allows all access from the server-side Admin SDK, which is necessary for our server actions.
    // This does not grant any permissions to client-side users.
    allow read, write: if request.auth == null;

    // --- Public Read Access ---
    // Make all files under the 'users/' and 'site-content/' paths publicly readable.
    // This is necessary for displaying avatars, collection covers, and card images.
    match /users/{userId}/{allPaths=**} {
      allow read;
    }
    match /site-content/{allPaths=**} {
      allow read;
    }

    // --- WRITE RULES (Clients-side) ---
    // By default, no client can write. The rules below grant specific write permissions.
    
    // USER PROFILE IMAGES
    match /users/{userId}/profile/{fileName} {
      allow write: if isOwner(userId) 
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
    
    // COLLECTION COVER IMAGES
    match /users/{userId}/collections/{collectionId}/{fileName} {
       allow write: if isOwner(userId)
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }
    
    // CARD IMAGES
     match /users/{userId}/cards/{cardId}/{fileName} {
       allow write: if isOwner(userId)
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }

    // SITE CONTENT IMAGES
    match /site-content/{allPaths=**} {
      allow write: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}

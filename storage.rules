
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow admin (server-side) full access.
    // This rule does not grant any client-side users access.
    match /{allPaths=**} {
      allow read, write: if request.auth.token.admin == true;
    }
    
    // --- Client-Side Rules ---

    // Allow profile picture reads by anyone
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
    }

    // Allow authenticated users to write to their own profile folder
    match /users/{userId}/profile/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow collection cover image reads by anyone
    match /users/{userId}/collections/{collectionId}/{fileName} {
      allow read: if true;
    }

    // Allow authenticated users to write to their own collection folders
     match /users/{userId}/collections/{collectionId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read access to site content images
    match /site-content/{allPaths=**} {
      allow read;
      // Only allow write access from the server (Admin SDK)
      allow write: if request.auth == null;
    }

    // --- User Specific Files ---
    // Rules for user-specific files (avatars, collection/card images)
    match /users/{userId}/{allPaths=**} {
      // Anyone can read public user content (like avatars for profiles)
      allow read;
      
      // Only the authenticated owner of the files can write (upload, update, delete)
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

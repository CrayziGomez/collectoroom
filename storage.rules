rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile pictures are publicly readable, but only the user can write to their own.
    match /users/{userId}/profile/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default rule: All other files are private and require authentication.
    // This rule is less specific, so the profile picture rule above will be checked first.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

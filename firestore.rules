rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Check if the user is an admin by reading their document
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isParticipant(chatId) {
      // Check if the user is a participant in a chat
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read: if true;
      allow list: if true;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /users/{userId}/following/{followingId} {
      // A user can modify their own 'following' list.
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    match /users/{userId}/followers/{followerId} {
      // A user can add/remove themselves from another user's 'followers' list.
      allow read: if true;
      allow write: if request.auth.uid == followerId;
    }

    match /collections/{collectionId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if resource.data.isPublic == true || (request.auth != null && (request.auth.uid == resource.data.userId || isAdmin()));
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /cards/{cardId} {
      // For a 'get' request (reading a single card), we can do an additional 'get' to check the parent.
      allow get: if get(/databases/$(database)/documents/collections/$(resource.data.collectionId)).data.isPublic == true 
                  || (request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/collections/$(resource.data.collectionId)).data.userId || isAdmin()));

      // For a 'list' request (querying cards), we cannot do additional 'get' calls.
      // The client-side query must be constructed securely first.
      allow list: if request.auth != null;

      // Rules for writing cards
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/collections/$(resource.data.collectionId)).data.userId || isAdmin());
    }
    
    match /categories/{categoryId} {
        allow read: if true;
        allow write: if request.auth != null && isAdmin();
    }

    match /chats/{chatId} {
      allow read, update, list: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isParticipant(chatId);
      allow create: if isParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
    }
    
    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, write, delete: if request.auth != null && isAdmin();
    }
    
    match /siteContent/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow list: if request.auth != null && request.auth.uid == request.query.where.recipientId;
      allow create: if request.auth != null; // Server-side logic must validate sender
    }
  }
}

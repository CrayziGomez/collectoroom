rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isParticipant(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read: if true;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /users/{userId}/following/{followingId} {
      allow read: if true;
      // A user can only modify their own "following" list
      allow write: if request.auth.uid == userId;
    }

    match /users/{userId}/followers/{followerId} {
      allow read: if true;
      // A user can only add/remove themselves from another user's "followers" list
      allow write: if request.auth.uid == followerId;
    }

    match /collections/{collectionId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.userId) || (request.auth != null && isAdmin());
      allow update: if (request.auth != null && request.auth.uid == resource.data.userId) || (request.auth != null && isAdmin());
      allow delete: if (request.auth != null && request.auth.uid == resource.data.userId) || (request.auth != null && isAdmin());
    }

    match /cards/{cardId} {
      function collectionIsPublic() {
        // This function is incorrect as written. It should be based on incoming data for create,
        // and existing data for read/update/delete.
        // A simplified and more robust approach is to pass collectionId in the card data.
        let collectionId = request.resource.data.collectionId; // For create
        if (request.method != 'create') {
          collectionId = resource.data.collectionId; // For other operations
        }
        return get(/databases/$(database)/documents/collections/$(collectionId)).data.isPublic == true;
      }

      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if collectionIsPublic() || (request.auth != null && request.auth.uid == resource.data.userId) || (request.auth != null && isAdmin());
      allow update: if (request.auth != null && request.auth.uid == resource.data.userId) || (request.auth != null && isAdmin());
      allow delete: if (request.auth != null && request.auth.uid == resource.data.userId) || (request.auth != null && isAdmin());
    }
    
    match /categories/{categoryId} {
        allow read: if true;
        allow write: if request.auth != null && isAdmin();
    }

    match /chats/{chatId} {
      allow read, update: if isParticipant(chatId);
      allow create: if request.auth.uid in request.resource.data.participantIds;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isParticipant(chatId);
      allow create: if isParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
    }
    
    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, write, delete: if request.auth != null && isAdmin();
    }
    
    match /siteContent/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow create: if request.auth != null; // Server-side logic should validate sender
    }
  }
}
